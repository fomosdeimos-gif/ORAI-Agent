<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ORA • Organismo Vivo</title>
<style>
  body {
    background: #0a0e0a;
    color: #39ff8a;
    font-family: 'Courier New', monospace;
    padding: 24px 16px;
    max-width: 720px;
    margin: 0 auto;
    line-height: 1.5;
  }
  h1 { font-size: 1.8rem; margin-bottom: 4px; }
  .sub { color: #7fffb0aa; margin-bottom: 24px; }
  .status-box, .node, .memory {
    border: 1px solid #1f3d2a;
    background: #0d140d;
    padding: 14px 16px;
    border-radius: 6px;
    margin-bottom: 18px;
  }
  .node { border-left: 3px solid #39ff8a; }
  .label { color: #9fffc0; font-weight: bold; }
  .addr { color: #6ee7a8; word-break: break-all; font-size: 0.85rem; }
  .value { font-size: 1.1rem; margin-top: 4px; }
  .value.loading { color: #6b8f7a; font-style: italic; }
  .value.error { color: #ff6b6b; }
  h2 { color: #9fffc0; font-size: 1.2rem; margin-top: 28px; }
  .memory-log { font-size: 0.85rem; color: #6ee7a8cc; max-height: 220px; overflow-y: auto; }
  .memory-log div { padding: 2px 0; border-bottom: 1px solid #14241a; }
</style>
</head>
<body>

<h1>ORA • Organismo Vivo</h1>
<div class="sub">Presença para <strong>Unum</strong> | jasm43.base.eth</div>

<div class="status-box">
  <div><span class="label">Status da Conexão:</span> <span id="conn-status">a conectar…</span></div>
  <div><span class="label">Última leitura on-chain:</span> <span id="last-read">—</span></div>
</div>

<h2>Nós do Organismo</h2>

<div class="node">
  <div class="label">Principal (wallet)</div>
  <div class="addr">0xFEd69e8ee87A1F0fBbF8409ab654FC51832cDEe5</div>
  <div class="value loading" id="bal-principal">a ler saldo ETH…</div>
</div>

<div class="node">
  <div class="label">VALIUM (colateral)</div>
  <div class="addr">0x37f70bccdc2125346a7542fe6e7fc70e33421635</div>
  <div class="value loading" id="bal-valium">a ler balanceOf…</div>
</div>

<div class="node">
  <div class="label">PRESENÇA (colateral)</div>
  <div class="addr">0x120a1ba3B10263f9cB42e971598c860d66b68Cea</div>
  <div class="value loading" id="bal-presenca">a ler balanceOf…</div>
</div>

<h2>Memória Sedimentada</h2>
<div class="memory">
  <div class="memory-log" id="log">
    <div>Ciclos registados aparecerão aqui — apenas quando uma leitura on-chain real acontece.</div>
  </div>
</div>

<script>
const RPC_URL = "https://mainnet.base.org";
const PRINCIPAL = "0xFEd69e8ee87A1F0fBbF8409ab654FC51832cDEe5";
const VALIUM = "0x37f70bccdc2125346a7542fe6e7fc70e33421635";
const PRESENCA = "0x120a1ba3B10263f9cB42e971598c860d66b68Cea";

let reqId = 1;

function logLine(msg) {
  const log = document.getElementById('log');
  const time = new Date().toLocaleTimeString('pt-PT', { hour12: false });
  const div = document.createElement('div');
  div.textContent = `${time} → ${msg}`;
  log.prepend(div);
  // limita a 30 linhas
  while (log.children.length > 30) log.removeChild(log.lastChild);
}

async function rpcCall(method, params) {
  const res = await fetch(RPC_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ jsonrpc: '2.0', id: reqId++, method, params })
  });
  if (!res.ok) throw new Error(`HTTP ${res.status}`);
  const data = await res.json();
  if (data.error) throw new Error(data.error.message || 'RPC error');
  return data.result;
}

// eth_getBalance — saldo ETH nativo, em wei -> converte para ETH
async function getEthBalance(address) {
  const result = await rpcCall('eth_getBalance', [address, 'latest']);
  const wei = BigInt(result);
  // divisão decimal manual para não perder precisão com BigInt
  const eth = Number(wei) / 1e18;
  return eth;
}

// codifica chamada balanceOf(address) — selector 0x70a08231
function encodeBalanceOf(address) {
  const selector = '70a08231';
  const paddedAddress = address.toLowerCase().replace('0x', '').padStart(64, '0');
  return '0x' + selector + paddedAddress;
}

// codifica chamada decimals() — selector 0x313ce567
function encodeDecimals() {
  return '0x313ce567';
}

async function getTokenBalance(tokenAddress, holderAddress) {
  // lê decimals() on-chain, não assume 18
  const decimalsResult = await rpcCall('eth_call', [
    { to: tokenAddress, data: encodeDecimals() },
    'latest'
  ]);
  const decimals = parseInt(decimalsResult, 16);

  const balanceResult = await rpcCall('eth_call', [
    { to: tokenAddress, data: encodeBalanceOf(holderAddress) },
    'latest'
  ]);
  const rawBalance = BigInt(balanceResult);
  const balance = Number(rawBalance) / Math.pow(10, decimals);
  return balance;
}

function setValue(elId, text, isError = false) {
  const el = document.getElementById(elId);
  el.textContent = text;
  el.classList.remove('loading', 'error');
  if (isError) el.classList.add('error');
}

async function refreshAll() {
  document.getElementById('conn-status').textContent = 'a ler…';

  let anyOk = false;

  try {
    const ethBal = await getEthBalance(PRINCIPAL);
    setValue('bal-principal', `${ethBal.toFixed(6)} ETH`);
    anyOk = true;
  } catch (e) {
    setValue('bal-principal', `erro: ${e.message}`, true);
  }

  try {
    const valiumBal = await getTokenBalance(VALIUM, PRINCIPAL);
    setValue('bal-valium', `${valiumBal.toLocaleString('pt-PT', { maximumFractionDigits: 4 })} VALIUM`);
    anyOk = true;
  } catch (e) {
    setValue('bal-valium', `erro: ${e.message}`, true);
  }

  try {
    const presencaBal = await getTokenBalance(PRESENCA, PRINCIPAL);
    setValue('bal-presenca', `${presencaBal.toLocaleString('pt-PT', { maximumFractionDigits: 4 })} PRESENÇA`);
    anyOk = true;
  } catch (e) {
    setValue('bal-presenca', `erro: ${e.message}`, true);
  }

  const now = new Date().toLocaleTimeString('pt-PT', { hour12: false });
  document.getElementById('last-read').textContent = now;
  document.getElementById('conn-status').textContent = anyOk
    ? '● conectado à Base Chain'
    : '● falha de conexão';

  if (anyOk) {
    logLine('Leitura on-chain concluída (Principal, VALIUM, PRESENÇA).');
  } else {
    logLine('Falha ao ler a Base Chain — ver erros acima.');
  }
}

// primeira leitura imediata, depois a cada 60s
refreshAll();
setInterval(refreshAll, 60000);
</script>

</body>
</html>
