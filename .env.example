# Configuração da Base Chain
BASE_CHAIN_RPC=https://mainnet.base.org

# Chave privada da carteira (NUNCA fazer commit com valores reais!)
WALLET_PRIVATE_KEY=0x

# Redis para cache
REDIS_URL=redis://localhost:6379

# Banco de dados
DATABASE_URL=postgresql://user:password@localhost/ora_db

# Intervalo de ciclos (segundos)
CYCLE_INTERVAL=300

# Logging
LOG_LEVEL=INFO
